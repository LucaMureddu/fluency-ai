# ─────────────────────────────────────────────────────────────
# Fluency 01 — Environment Variables
# Copia questo file in .env e inserisci i tuoi valori.
# ATTENZIONE: non committare mai il file .env su Git.
# ─────────────────────────────────────────────────────────────

# [OBBLIGATORIO] Chiave API Groq — gratuita su https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# [Opzionale] Modello Whisper per la trascrizione
# Opzioni: base (default, veloce) | small (più accurato) | medium (lento ma preciso)
WHISPER_MODEL=base

# [Opzionale] Voce TTS Microsoft Neural
# US: en-US-GuyNeural | en-US-JennyNeural | en-US-AriaNeural
# UK: en-GB-RyanNeural
# AU: en-AU-NatashaNeural
VOICE_MODEL=en-US-GuyNeural

# [Opzionale] Parametri LLM
MAX_TOKENS=512
TEMPERATURE=0.7
